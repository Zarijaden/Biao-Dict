<%
// 读取词典数据并按汉语拼音首字母分组
const dict = site.data.dict || [];
// 保存原始索引，用于搜索定位
dict.forEach((item, idx) => { item._idx = idx; });
const groups = {};

dict.forEach(item => {
  const initial = item.initial || '#';
  if (!groups[initial]) groups[initial] = [];
  groups[initial].push(item);
});

// 每组内按首个汉字的拼音全拼排序
Object.keys(groups).forEach(letter => {
  groups[letter].sort((a, b) =>
    (a.pinyin_full || '').localeCompare(b.pinyin_full || '')
  );
});

// 字母组在前，# 在最后
const sortedKeys = Object.keys(groups).sort((a, b) => {
  if (a === '#') return 1;
  if (b === '#') return -1;
  return a.localeCompare(b);
});
%>

<div class="dict-search">
  <input type="text" class="dict-search-input" placeholder="搜索词条…" autocomplete="off">
  <div class="dict-search-results" style="display:none;"></div>
</div>

<div class="note">
  <% if (theme.index && theme.index.note) { %>
    <p class="note-text"><%- theme.index.note.replace(/\n/g, '<br>') %></p>
  <% } %>
</div>

<div class="dict">
  <% if (sortedKeys.length === 0) { %>
    <p class="dict-empty">暂无词条。</p>
  <% } else { %>
    <% sortedKeys.forEach(letter => { %>
      <div class="dict-group">
        <h2 class="dict-letter"><%= letter %></h2>
        <div class="dict-words">
          <% groups[letter].forEach(item => { %>
            <span class="dict-entry" id="entry-<%= item._idx %>"><%= item.word %> <span class="dict-pinyin">[<%= item.ipa %>]</span></span>
          <% }); %>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>

<script>
(function() {
  const DICT_DATA = <%- JSON.stringify(dict) %>;
  const input = document.querySelector('.dict-search-input');
  const results = document.querySelector('.dict-search-results');
  let activeIdx = -1;

  if (!input || !results || !DICT_DATA.length) return;

  function escapeHtml(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  function doSearch(query) {
    var q = query.trim().toLowerCase();
    if (!q) { results.style.display = 'none'; results.innerHTML = ''; return; }

    var matches = [];
    for (var i = 0; i < DICT_DATA.length; i++) {
      var item = DICT_DATA[i];
      if (item.word.indexOf(q) !== -1 ||
          (item.pinyin_full || '').toLowerCase().indexOf(q) !== -1 ||
          (item.ipa || '').indexOf(q) !== -1) {
        matches.push(item);
      }
      if (matches.length >= 20) break;
    }

    if (!matches.length) {
      results.style.display = 'block';
      results.innerHTML = '<div class="dict-search-empty">无匹配词条</div>';
      activeIdx = -1;
      return;
    }

    var html = '';
    for (var j = 0; j < matches.length; j++) {
      var m = matches[j];
      html += '<div class="dict-search-item" data-idx="' + m._idx + '">' +
              escapeHtml(m.word) +
              ' <span class="dict-search-item-ipa">[' + escapeHtml(m.ipa) + ']</span>' +
              '</div>';
    }
    results.innerHTML = html;
    results.style.display = 'block';
    activeIdx = -1;
  }

  input.addEventListener('input', function() {
    doSearch(this.value);
  });

  input.addEventListener('keydown', function(e) {
    var items = results.querySelectorAll('.dict-search-item');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      activeIdx = Math.min(activeIdx + 1, items.length - 1);
      highlightItem(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      activeIdx = Math.max(activeIdx - 1, 0);
      highlightItem(items);
    } else if (e.key === 'Enter') {
      e.preventDefault();
      if (activeIdx >= 0 && items[activeIdx]) {
        selectItem(items[activeIdx]);
      }
    } else if (e.key === 'Escape') {
      results.style.display = 'none';
      activeIdx = -1;
    }
  });

  function highlightItem(items) {
    for (var k = 0; k < items.length; k++) {
      items[k].classList.remove('active');
    }
    if (activeIdx >= 0 && items[activeIdx]) {
      items[activeIdx].classList.add('active');
    }
  }

  results.addEventListener('click', function(e) {
    var item = e.target.closest('.dict-search-item');
    if (item) selectItem(item);
  });

  function selectItem(item) {
    var idx = item.getAttribute('data-idx');
    var el = document.getElementById('entry-' + idx);
    results.style.display = 'none';
    input.value = '';
    activeIdx = -1;
    if (el) {
      // 移除之前的高亮
      var prev = document.querySelector('.dict-entry.highlight');
      if (prev) prev.classList.remove('highlight');
      el.classList.add('highlight');
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  // 点击外部关闭下拉
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.dict-search')) {
      results.style.display = 'none';
      activeIdx = -1;
    }
  });
})();
</script>
