<!DOCTYPE html>
<html lang="zh-Hans">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="icon" type="image/png" href="<%= url_for(theme.favicon) %>" sizes="192x192">
  <title><%= is_home() ? config.title : config.title + ' - ' + page.title %></title>
  <link rel="stylesheet" href="<%= url_for('/css/style.css') %>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <div class="page-wrapper">
  <header class="site-header">
    <nav class="site-nav">
      <a class="site-title" href="<%= url_for('/') %>"><%= config.title %></a>
      <div class="site-nav-links">
      <% for (const label in theme.nav) {
        const href = theme.nav[label];
        const isExternal = !href.startsWith('/');
        const navPath = href.replace(/^\/+/, '');
        const curPath = page.path || '';
        const isHome = navPath === '' && (curPath === '' || curPath === 'index.html');
        const isActive = !isExternal && (isHome || (navPath && curPath.startsWith(navPath)));
      %>
        <a href="<%= isExternal ? href : url_for(href) %>" class="<%= isActive ? 'active' : '' %>"><%= label %></a>
      <% } %>
      </div>
    </nav>
  </header>

  <main class="site-main">
    <%- body %>
  </main>
  </div>
  <footer class="site-footer">
    <span>自 <%= theme.since || '未知' %> · 已收录 <%= site.data.dict ? site.data.dict.length : 0 %> 个词条 · 手工维护</span>
  </footer>
</body>
</html>